{
  "name": "bubblegum",
  "version": "1.0.0",
  "description": "Core of my world :)",
  "main": "index.js",
  "scripts": {
    "start": "node server/index.js",
    "serve": "nodemon server/index.js",
    "serve:netlify": "netlify-lambda -c ./webpack.functions.js serve server-netlify",
    "build:netlify": "netlify-lambda -c ./webpack.functions.js build server-netlify",
    "deploy:netlify": "netlify deploy --prod",
    "predeploy": "git push origin master",
    "lint": "eslint",
    "lint:err": "eslint --quiet",
    "format": "prettier --write .",
    "check-deps": "npx npm-check-updates --target semver",
    "update-deps": "npx npm-check-updates --target semver --upgrade && npm install"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/joi": "^15.1.1",
    "@notionhq/client": "^2.3.0",
    "@sendgrid/mail": "^7.7.0",
    "apollo-server-express": "^2.26.2",
    "apollo-server-lambda": "^3.13.0",
    "bcrypt": "^5.1.1",
    "chalk": "^3.0.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^8.6.0",
    "express": "^4.22.1",
    "express-jwt": "^5.3.3",
    "firebase-admin": "^8.13.0",
    "google-auth-library": "^5.10.1",
    "googleapis": "^73.0.0",
    "graphql": "^15.10.2",
    "graphql-scalars": "^1.25.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "mongoose": "^5.13.23",
    "morgan": "^1.10.1",
    "multer": "^1.4.4",
    "netlify-lambda": "^2.0.16",
    "nodemailer": "^6.10.1",
    "rss-parser": "^3.13.0",
    "serverless-http": "^2.7.0",
    "slug": "^5.3.0",
    "socket.io": "^2.5.1",
    "streamifier": "^0.1.1",
    "uuid": "^3.4.0"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^1.19.4",
    "prettier": "3.8.2",
    "webpack-node-externals": "^3.0.0"
  }
}